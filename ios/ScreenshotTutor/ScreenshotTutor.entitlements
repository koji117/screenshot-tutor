<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Lifts the per-app memory cap on supported iPads/iPhones so we can
         hold a 3GB+ VLM in RAM during inference. Without this, iOS jetsam
         kills the process the moment we cross the default ~2GB-ish
         budget, which is what users hit when loading Gemma 4 E4B. The
         entitlement is honoured on real devices that have headroom; on
         older devices iOS simply ignores it. Free Personal Team certs
         can sign with this entitlement. -->
    <key>com.apple.developer.kernel.increased-memory-limit</key>
    <true/>

    <!-- Pairs with the above on iOS 18+ to give the process a full 64-bit
         address range, so memory mapping of a multi-GB weight file
         doesn't fragment the address space. -->
    <key>com.apple.developer.kernel.extended-virtual-addressing</key>
    <true/>
</dict>
</plist>
